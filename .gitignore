# Heavy artifacts live on the box (/ephemeral) and are re-downloadable — never in git
weights/
models/
outputs/
hf/
episodes/*/stills/
episodes/*/clips/
episodes/*/voice/
episodes/*/captions/
episodes/*/final/
*.safetensors
*.ckpt
*.gguf
*.pt
*.bin
*.png
*.jpg
*.jpeg
*.mp4
*.wav
*.mov

# ...EXCEPT canonical character reference sheets: these are the no-LoRA identity
# artifact (committed on purpose, like the LoRA file is stored on HF).
!character/*/refs/
!character/*/refs/*.png
!character/*/refs/*.jpg


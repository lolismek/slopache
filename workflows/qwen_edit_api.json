{
  "11": {
    "class_type": "UNETLoader",
    "_meta": {"title": "Load Diffusion Model"},
    "inputs": {"unet_name": "qwen_image_edit_2511_fp8mixed.safetensors", "weight_dtype": "default"}
  },
  "12": {
    "class_type": "CLIPLoader",
    "_meta": {"title": "Load CLIP (Qwen2.5-VL)"},
    "inputs": {"clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors", "type": "qwen_image", "device": "default"}
  },
  "13": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {"vae_name": "qwen_image_vae.safetensors"}
  },
  "14": {
    "class_type": "LoadImage",
    "_meta": {"title": "Founder Image"},
    "inputs": {"image": "pixar_portrait_b_00001_.png"}
  },
  "15": {
    "class_type": "ImageScaleToTotalPixels",
    "_meta": {"title": "Scale to ~1MP"},
    "inputs": {"image": ["14", 0], "upscale_method": "lanczos", "megapixels": 1.0, "resolution_steps": 1}
  },
  "16": {
    "class_type": "ModelSamplingAuraFlow",
    "_meta": {"title": "Model Sampling Shift"},
    "inputs": {"model": ["11", 0], "shift": 3.0}
  },
  "17": {
    "class_type": "CFGNorm",
    "_meta": {"title": "CFG Norm"},
    "inputs": {"model": ["16", 0], "strength": 1.0, "pre_cfg": false}
  },
  "20": {
    "class_type": "TextEncodeQwenImageEdit",
    "_meta": {"title": "POSITIVE_PROMPT"},
    "inputs": {"clip": ["12", 0], "vae": ["13", 0], "image": ["15", 0], "prompt": "Keep the same woman, same clothing, same 3D Pixar style. Show her front-facing, head and shoulders, gentle smile, soft warm window light."}
  },
  "21": {
    "class_type": "TextEncodeQwenImageEdit",
    "_meta": {"title": "NEGATIVE_PROMPT"},
    "inputs": {"clip": ["12", 0], "vae": ["13", 0], "image": ["15", 0], "prompt": "distorted face, deformed, melted or puffed features, asymmetric eyes, warped mouth, blurry, low quality"}
  },
  "22": {
    "class_type": "VAEEncode",
    "_meta": {"title": "Encode Source Latent"},
    "inputs": {"pixels": ["15", 0], "vae": ["13", 0]}
  },
  "30": {
    "class_type": "KSampler",
    "_meta": {"title": "Sampler"},
    "inputs": {"model": ["17", 0], "seed": 1000, "steps": 30, "cfg": 4.0, "sampler_name": "euler", "scheduler": "simple", "positive": ["20", 0], "negative": ["21", 0], "latent_image": ["22", 0], "denoise": 1.0}
  },
  "40": {
    "class_type": "VAEDecode",
    "_meta": {"title": "Decode"},
    "inputs": {"samples": ["30", 0], "vae": ["13", 0]}
  },
  "41": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save"},
    "inputs": {"images": ["40", 0], "filename_prefix": "dataset"}
  }
}

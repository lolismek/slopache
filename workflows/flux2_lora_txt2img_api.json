  },
  "21": {
    "class_type": "FluxGuidance",
    "inputs": {"conditioning": ["20", 0], "guidance": 4.0},
    "_meta": {"title": "Flux Guidance"}
  },
  "22": {
    "class_type": "BasicGuider",
    "inputs": {"model": ["15", 0], "conditioning": ["21", 0]},
    "_meta": {"title": "Guider"}

  "30": {
    "class_type": "EmptyFlux2LatentImage",
    "inputs": {"width": 768, "height": 1344, "batch_size": 1},
    "_meta": {"title": "Empty Latent"}
  },
  "31": {
    "class_type": "Flux2Scheduler",
    "inputs": {"steps": 20, "width": 768, "height": 1344},
    "_meta": {"title": "Scheduler"}
  },
  "32": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler"},
    "_meta": {"title": "Sampler Select"}
  },
  "33": {
    "class_type": "RandomNoise",
    "inputs": {"noise_seed": 0},
    "_meta": {"title": "Noise"}
  },
  "34": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {"noise": ["33", 0], "guider": ["22", 0], "sampler": ["32", 0], "sigmas": ["31", 0], "latent_image": ["30", 0]},
    "_meta": {"title": "Sampler"}
  },
  "40": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["34", 0], "vae": ["12", 0]},
    "_meta": {"title": "Decode"}
  },
  "41": {
    "class_type": "SaveImage",
    "inputs": {"images": ["40", 0], "filename_prefix": "img"},
    "_meta": {"title": "Save"}
  }
}

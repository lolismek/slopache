# Brev box connection. The IP is resolved dynamically by remote.sh from
# ~/.brev/ssh_config, so this survives instance restarts (the IP can change).
BREV_INSTANCE=senior-salmon-yak
BOX_USER=shadeform
BOX_KEY="$HOME/.brev/brev.pem"

# Everything heavy lives on the 700GB /ephemeral volume, NOT the 97GB root.
# WARNING: /ephemeral is scratch/cache storage — it may be wiped if the instance
# is deprovisioned. The git repo (synced from local) is the source of truth for
# code/config; model weights are re-downloadable via env/download_models.sh.
REMOTE_ROOT=/ephemeral/slopache
COMFY_DIR=/ephemeral/ComfyUI
COMFY_PORT=8188
